{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "wiki-graph-core": ["packages/core/src/index.ts"],
      "wiki-graph-core/gc": ["packages/core/src/gc.ts"],
      "wiki-graph-core/worker": ["packages/core/src/worker.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "test/**/*.ts",
    "eslint.config.mjs",
    "packages/*/tsup.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["packages/*/dist", "dist", "coverage", "node_modules"]
}
