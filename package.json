{
  "name": "wiki-graph-workspace",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=8192 pnpm -r --sort run build",
    "coverage:report": "node ./scripts/coverage-report.mjs",
    "cli:clean-dev-state": "rimraf .wikigraph",
    "cli:install-local": "node ./scripts/install-local-cli.mjs",
    "cli:uninstall-local": "npm uninstall -g wiki-graph",
    "dev": "pnpm --filter wiki-graph dev",
    "fixtures:generate": "node ./scripts/generate-test-fixtures.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier . --write",
    "prepack": "pnpm build",
    "publish:cli": "pnpm --filter wiki-graph publish --access public",
    "publish:core": "pnpm --filter wiki-graph-core publish --access public",
    "publish:dry-run:cli": "pnpm --filter wiki-graph publish --dry-run --access public --no-git-checks",
    "publish:dry-run:core": "pnpm --filter wiki-graph-core publish --dry-run --access public --no-git-checks",
    "release:check:cli": "pnpm verify && pnpm test:run && pnpm build && pnpm smoke:pack-install && pnpm publish:dry-run:cli",
    "release:check:core": "pnpm verify && pnpm test:run && pnpm build && pnpm smoke:pack-install && pnpm publish:dry-run:core",
    "smoke:pack-install": "node ./scripts/smoke-pack-install.mjs",
    "eval:llm": "tsx ./evals/summarize-self-talk.ts",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.6.1",
    "@types/nunjucks": "^3.2.6",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "@vitest/coverage-v8": "^4.1.4",
    "ai": "^6.0.154",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tinyld": "^1.3.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.4",
    "yauzl": "^3.3.0",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  }
}
