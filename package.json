{
  "name": "spinedigest",
  "version": "0.1.5",
  "description": "CLI-first tool for digesting long-form text and ebooks into compressed text, EPUB, or reusable .sdpub archives.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oomol-lab/spinedigest.git"
  },
  "bugs": {
    "url": "https://github.com/oomol-lab/spinedigest/issues"
  },
  "homepage": "https://github.com/oomol-lab/spinedigest",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "data",
    "dist",
    "LICENSE"
  ],
  "bin": {
    "spinedigest": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && tsup --config tsup.config.ts && node ./scripts/write-esm-wrappers.mjs",
    "coverage:report": "node ./scripts/coverage-report.mjs",
    "cli:install-local": "node ./scripts/install-local-cli.mjs",
    "cli:uninstall-local": "npm uninstall -g spinedigest",
    "dev": "tsx src/cli.ts",
    "fixtures:generate": "node ./scripts/generate-test-fixtures.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier . --write",
    "prepack": "pnpm build",
    "publish:dry-run": "npm publish --dry-run --access public",
    "release:check": "pnpm verify && pnpm test:run && pnpm build && pnpm smoke:pack-install && pnpm publish:dry-run",
    "smoke:pack-install": "node ./scripts/smoke-pack-install.mjs",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm format:check"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/google": "^3.0.61",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "ai": "^6.0.154",
    "htmlparser2": "^12.0.0",
    "jsonrepair": "^3.13.3",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "saxes": "^6.0.0",
    "sqlite3": "^6.0.1",
    "tinyld": "^1.3.4",
    "yauzl": "^3.3.0",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.6.1",
    "@types/nunjucks": "^3.2.6",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.4"
  }
}
